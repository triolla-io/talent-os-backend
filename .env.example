# Database — PostgreSQL 16 (matches docker-compose.yml postgres service)
DATABASE_URL=postgresql://triolla:password@postgres:5432/triolla

# Queue — Redis 7 (matches docker-compose.yml redis service)
REDIS_URL=redis://redis:6379

# AI — OpenRouter (openai/gpt-4o-mini for extraction and scoring)
OPENROUTER_API_KEY=sk-or-...

# Email intake — Mailgun webhook signing key (Mailgun dashboard → Webhooks → HTTP webhook signing key)
MAILGUN_WEBHOOK_SIGNING_KEY=

# Multi-tenancy — hardcoded dev tenant UUID (Phase 1 has exactly one tenant)
TENANT_ID=00000000-0000-0000-0000-000000000001

# Cloudflare R2 object storage (S3-compatible) — stores original CV files
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=triolla-cvs

# Runtime environment
NODE_ENV=production

# PostgreSQL superuser password (for docker-compose postgres service)
POSTGRES_PASSWORD=changeme

# ─── Authentication (JWT) ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# Minimum 32 characters required — app will fail to start if missing or too short
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-in-production

# ─── Auth v2.0 — Email (SMTP) ─────────────────────────────────────────────────
# Leave blank in dev — emails are logged to console when SMTP_HOST is absent
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@mg.triolla.io
SMTP_PASS=
SMTP_FROM="Talent OS <noreply@mg.triolla.io>"
FRONTEND_URL=http://localhost:5173
GOOGLE_CLIENT_ID=   # optional — leave blank for dev stub

# ─── PM Bridge — Jira integration ────────────────────────────────────────────
# Required — app will refuse to start if JIRA_BASE_URL / JIRA_EMAIL / JIRA_API_TOKEN are absent
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_EMAIL=you@yourorg.io
JIRA_API_TOKEN=                             # Atlassian API token (never logged)
JIRA_PROJECT_KEY=TO                         # default: TO
JIRA_SPRINT_ID=                             # numeric sprint ID — new issues are added to this sprint automatically
PM_BRIDGE_ALLOWLIST=                        # comma-separated emails; empty = no one allowed
PM_BRIDGE_MODEL=anthropic/claude-sonnet-4.6

# MCP server (talent-os-mcp process)
MCP_PUBLIC_URL=http://localhost:3100        # public base URL; OAuth audience + discovery
MCP_JWT_SECRET=change-me-min-32-characters-long-xxxxx   # ≥32 chars, DISTINCT from JWT_SECRET
