{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "transformIgnorePatterns": ["node_modules/(?!@openrouter|jose)"],
  "moduleNameMapper": {
    "^@openrouter/sdk$": "<rootDir>/__mocks__/@openrouter/sdk.js"
  }
}
